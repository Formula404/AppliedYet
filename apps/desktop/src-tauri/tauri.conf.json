{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "投了吗",
  "version": "0.3.0",
  "identifier": "com.appliedyet.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "投了吗 · Applied Yet?",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self'; object-src 'none'; base-uri 'none'; frame-src 'none'; form-action 'none'",
      "devCsp": "default-src 'self' http://localhost:1421; connect-src ipc: http://ipc.localhost http://localhost:1421 ws://localhost:1421; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self'; object-src 'none'; base-uri 'none'; frame-src 'none'; form-action 'none'",
      "freezePrototype": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "本地优先的个人求职全流程工作台",
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh",
        "sidebarImage": "installer/sidebar-1.bmp",
        "headerImage": "installer/header.bmp"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQzQzNBOTk0RTFEMERGQ0QKUldUTjM5RGhsS25EUS9HUVNUWVVrS3ZZTmRSVEhRc2J2R3BGRGkvVHVWTE1CWEZYdHFyUlBkaDAK",
      "endpoints": [
        "https://github.com/Formula404/AppliedYet/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
